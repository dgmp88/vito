# OpenAI API key. Used server-side only:
#   - to mint ephemeral tokens for realtime transcription (gpt-realtime-whisper)
#   - to proxy the streaming chat completion (gpt-5.5)
# The browser never sees this key.
OPENAI_API_KEY=sk-...

# Optional overrides (defaults shown).
# VITO_TRANSCRIBE_MODEL=gpt-realtime-whisper
# VITO_CHAT_MODEL=gpt-5.5

# Neon Auth (optional). Email/password login via https://neon.com/docs/auth/overview.
# Copy the Auth Base URL from the Neon Console (your project → Auth).
# When unset, the app runs without login and conversations stay in localStorage.
# When set, conversations persist to Neon Postgres, scoped to the signed-in user.
# VITE_-prefixed: exposed to the browser (it's a public endpoint URL, not a secret).
# VITE_NEON_AUTH_URL=https://ep-xxx.neonauth.us-east-2.aws.neon.build/neondb/auth

# Neon Postgres connection string (server-side only). Required when Neon Auth is
# enabled — it's where conversations, messages, and documents are stored. Get it
# from the Neon Console (your project → Connection Details).
# DATABASE_URL=postgresql://user:password@ep-xxx.aws.neon.build/neondb?sslmode=require

# Optional: override the JWKS endpoint used to verify session tokens server-side.
# Defaults to <VITE_NEON_AUTH_URL>/jwks; set only if your deployment differs.
# NEON_JWKS_URL=https://ep-xxx.neonauth.us-east-2.aws.neon.build/neondb/auth/jwks
